{
	"compilerOptions": {
		"incremental": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "react",
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "lib",
		"resolveJsonModule": true,
		"strict": true,
		"esModuleInterop": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"target": "ES2020",
		"lib": [
			"ESNext",
			"DOM"
		]
	},
	"exclude": [
		"node_modules"
	]
}