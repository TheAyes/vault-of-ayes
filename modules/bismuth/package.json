{
	"name": "@vault-of-ayes/bismuth",
	"description": "Blank project with routing included",
	"engines": {
		"node": "^18.17.0 || ^20.3.0 || >=21.0.0"
	},
	"engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
	"private": true,
	"trustedDependencies": [
		"sharp"
	],
	"trustedDependencies-annotation": "Needed for bun to allow running install scripts",
	"type": "module",
	"scripts": {
		"build": "qwik build",
		"build-storybook": "storybook build",
		"build.client": "vite build",
		"build.preview": "vite build --ssr src/entry.preview.tsx",
		"build.types": "tsc --incremental --noEmit",
		"deploy": "echo 'Run \"npm run qwik add\" to install a server adapter'",
		"dev": "vite --mode ssr",
		"dev.debug": "bun --inspect-brk ../../node_modules/vite/bin/vite.js --mode ssr --force",
		"fmt": "prettier --write .",
		"fmt.check": "prettier --check .",
		"lint": "eslint \"src/**/*.ts*\"",
		"preview": "qwik build preview && vite preview --open",
		"start": "vite --open --mode ssr",
		"storybook": "storybook dev -p 6006",
		"test.e2e": "playwright test",
		"tauri": "tauri",
		"qwik": "qwik"
	},
	"devDependencies": {
		"@builder.io/qwik": "^1.9.0",
		"@builder.io/qwik-city": "^1.9.0",
		"@playwright/test": "^1.38.1",
		"@qwik-ui/headless": "^0.6.0",
		"@storybook/addon-essentials": "^8.2.8",
		"@storybook/addon-links": "^8.2.8",
		"@storybook/blocks": "^8.2.8",
		"@storybook/builder-vite": "^8.2.8",
		"@storybook/html": "^8.2.8",
		"@storybook/html-vite": "^8.2.8",
		"@tauri-apps/cli": "^1.6.2",
		"@types/eslint": "8.56.10",
		"@types/node": "20.14.11",
		"@typescript-eslint/eslint-plugin": "7.16.1",
		"@typescript-eslint/parser": "7.16.1",
		"autoprefixer": "^10.4.14",
		"cssnano": "^7.0.6",
		"eslint": "8.57.0",
		"eslint-plugin-qwik": "^1.9.0",
		"motion": "^10.18.0",
		"postcss": "^8.4.31",
		"postcss-preset-env": "^9.1.0",
		"prettier": "3.3.3",
		"storybook": "^8.2.8",
		"storybook-framework-qwik": "^0.4.0",
		"typescript": "5.4.5",
		"undici": "*",
		"vite": "5.3.5",
		"vite-tsconfig-paths": "^4.2.1"
	}
}
